# PRD Knowledge Base - Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://prd_user:CHANGE_ME@db:5432/prd_knowledge_base
POSTGRES_PASSWORD=CHANGE_ME

# 百炼 API (阿里云通义千问) - 主要 LLM
QWEN_API_KEY=sk-xxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max  # 可选: qwen-plus, qwen-turbo

# Anthropic API (可选，备用)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=

# Voyage AI (可选，优先使用本地 embedding 模型)
VOYAGE_API_KEY=pa-xxx

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000", "http://YOUR_SERVER_IP:3000"]

# Upload directory
UPLOAD_DIR=./uploads

# Feishu / Lark (可选)
FEISHU_APP_ID=
FEISHU_APP_SECRET=